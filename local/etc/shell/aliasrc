# vim: filetype=sh

[ -x /bin/nvim ] && alias vim=nvim vimdiff='nvim -d'
[ -f "$XINITRC" ] && alias startx='startx $XINITRC'
[ -f "$MBSYNCRC" ] && alias mbsync='mbsync -c $MBSYNCRC'

for command in \
	mount umount sv pacman updatedb su shutdown poweroff reboot
do
	alias $command="sudo $command"
done; unset command

se(){ c=`find $DOTS/bin -type f -print | fzf -d / --with-nth -1`; [ $c ]&& $EDITOR $c ;}
g() { l=${1:-`xclip -o`}; if test "$l" && git clone "$l"; then cd `basename "$l" .git`; git config remote.pushdefault origin; git config push.default current; fi }
u() { if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then git add -A; git commit -m "update `date '+%Y%m%d_%H%M%S'`" && git push; fi }

# Verbosity and settings that you pretty much just always are going to want.
alias \
	cp='cp -iv' \
	cp1='safe cp' \
	mv='mv -iv' \
	mv1='safe mv' \
	rm='rm -vI' \
	bc='bc -ql' \
	rsync='rsync -vrPlu' \
	mkd='mkdir -pv' \
	y='yt-dlp "$(xclip -o)"' \
	t=tsp \
	ffmpeg='ffmpeg -hide_banner' \
	a=ani-cli \
	aa='ani-cli -c'

# Colorize commands when possible.
alias \
	ls='ls -hN --color=auto --group-directories-first' \
	grep='grep --color=auto' \
	diff='diff --color=auto' \
	ip='ip -color=auto'

# These common commands are just too long! Abbreviate them.
alias \
	ka=killall \
	trem=transmission-remote \
	e='$EDITOR' \
	v='$EDITOR' \
	p=pacman \
	cl='pacman -Qdtq | pacman -Rns - ; pacman -Qqd | pacman -Rsu -' \
	z='pacman -Syu'

alias \
	lf=lfub \
	ref='shortcuts >/dev/null; source ${XDG_CONFIG_HOME?}/shell/shortcutrc ; source ${XDG_CONFIG_HOME?}/shell/zshnameddirrc'
