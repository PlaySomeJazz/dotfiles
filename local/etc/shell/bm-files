# These files automatically update when edited/saved in vim:

# keys	filename				description
bf	$XDG_CONFIG_HOME/shell/bm-files		# This file, a list of bookmarked files
bd	$XDG_CONFIG_HOME/shell/bm-dirs		# A list of bookmarked directories similar to this file
cfx	$XDG_CONFIG_HOME/x11/xresources		# Colors, themes and variables for X11
cfd	${DOTS:-$HOME/local}/src/dwm/config.h


# These do not update automatically, but on the next new instance of a program:

cfv	$XDG_CONFIG_HOME/nvim/init.vim		# vim/neovim config
cfz	$ZDOTDIR/.zshrc				# zsh (shell) config
cfa	$XDG_CONFIG_HOME/shell/aliasrc		# aliases used by zsh (and potentially other shells)
cfp	$XDG_CONFIG_HOME/zsh/.zprofile		# profile file for login settings for zsh
cfn	$XDG_CONFIG_HOME/newsboat/config	# newsboat (RSS reader)
cfu	$XDG_CONFIG_HOME/newsboat/urls		# RSS urls for newsboat
cfmb	$XDG_CONFIG_HOME/ncmpcpp/bindings	# ncmpcpp (music player) keybinds file
cfmc	$XDG_CONFIG_HOME/ncmpcpp/config		# ncmpcpp (music player) config
cfl	$XDG_CONFIG_HOME/lf/lfrc		# lf (file browser) config
cfL	$XDG_CONFIG_HOME/lf/previewer		# lf's scope/preview file
cfX	${DOTS:-$HOME/local}/bin/key-handler	# nsxiv (image viewer) key/script handler
tt	$NOTES_FILE
