#!/bin/sh
inbox=${1:-$NOTES_FILE} def=Chores addc='<Add category>' deln='<Delete>'

log() { printf "\033[2K\r\033[1;${2:-33}m${1}\033[0m"; }
add() { printf '%s\n' "$*" >>$c && del; }
del() { ed - $inbox <<-\#
	1d
	w
	#
}
case $inbox in [!/]*) inbox=`pwd`/$inbox; esac
test ! -f "$inbox"      && log 'Missing file\n' 31 && exit
test ! -d ${NOTES_DIR?} && mkdir -p $NOTES_DIR

chdir $NOTES_DIR
>>$def
while test -s $inbox; do
	tput clear
	read -r note <$inbox; test "X$note" = X && del && continue
	log "$note\n\n"
	c=`printf '%s\n' * "$addc" "$deln" | fzf`
	case $c in
	"$addc")	log 'Enter title:\n' 36; read c; test "X$c" = X && continue
			test ! -f "$c" && add "$note" ||
				{ tput clear; log 'Duplicate\n' 31; sleep 1;} ;;
	"$deln")	log 'Delete?' 31; a=`printf '%s\n' yes no | fzf`
			test "$a" = yes && del;;
	'')		tput clear; log 'Interrupted\n' 31; exit;;
	*)		add "$note"
	esac
done

tput clear
for i in *; do test -s $i && mail -s $i $USER <$i &&  >$i; done
log 'All done!\n' 34
