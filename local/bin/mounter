#!/bin/dash

set -e

case $1 in
unmount)
	LIST=`
		: MOUNTED PHONES
		findmnt -Pno SOURCE,TARGET | while IFS= read -r line; do
			eval "$line"
			case $SOURCE in
			simple-mtpfs-*) printf 'đź“±%s (%s)\n' "$SOURCE" "$TARGET"
			esac
		done
		: MOUNTED DRIVES
		findmnt --real -Pno SOURCE,TARGET,SIZE | while IFS= read -r line; do
			eval "$line"
			case $SOURCE in simple-mtpfs-*) continue; esac
			case $TARGET in
			""|/|*/boot*|*/home) continue
			esac
			printf 'đź’ľ%s (%s, %s)\n' "$TARGET" "$SOURCE" "$SIZE"
		done
	`
	test "$LIST"
	chosen=`printf '%s\n' "$LIST" | dmenu -i -p 'Unmount which drive?'`
	test "$chosen"
	case $chosen in
	đź’ľ*)	target=${chosen#đź’ľ}
		target=${target%% (*}
		;;
	đź“±*)	fsname=${chosen#đź“±}
		fsname=${fsname%% (*}
		target=`findmnt -no TARGET -S "$fsname"`
	esac
	sudo umount -l "$target"
	notify-send "Device unmounted" "$chosen has been unmounted"
	exit
esac

LIST=`
	: MOUNTABLE PHONES
	simple-mtpfs -l 2>/dev/null | while IFS= read -r line; do
		mtpnum=${line%%:*}
		findmnt -n -S "simple-mtpfs-$mtpnum" >/dev/null 2>&1 ||
		printf 'đź“±%s\n' "$line"
	done
	: MOUNTABLE PARTITIONS
	lsblk -Ppo NAME,TYPE,SIZE,LABEL,FSTYPE,MOUNTPOINT | while IFS= read -r line; do
		eval "$line"
		if test \( "$TYPE" != part -a "$TYPE" != rom \) -o -n "$MOUNTPOINT"
		then	continue
		fi
		printf 'đź’ľ%s (%s%s%s)\n' "$NAME" "$SIZE" "${LABEL:+, $LABEL}" "${FSTYPE:+, $FSTYPE}"
	done
`

test "$LIST"
chosen=`printf '%s\n' "$LIST" | dmenu -i -p 'Mount which drive?'`

getmount() {
	mountpoint=`find /mnt /media /usr/$USER -maxdepth 1 -type d -empty 2>/dev/null | dmenu -i -p 'Mount this drive where?'`
	test "$mountpoint"
	if [ ! -d "$mountpoint" ]; then
		a=`printf 'No\nYes' | dmenu -i -p "$mountpoint does not exist. Create it?"`
		case $a in
		Yes)	mkdir -p "$mountpoint" || sudo mkdir -p "$mountpoint"
		esac
	fi
}

case $chosen in
đź’ľ*)	device=${chosen#đź’ľ}
	device=${device%% (*}
	if sudo mount "$device"; then
		notify-send "đź’ľ Drive Mounted" "$device mounted"
		exit
	fi
	getmount
	fstype=`lsblk -nro FSTYPE "$device"`
	case $fstype in
		vfat) sudo mount -t vfat "$device" "$mountpoint" -o rw,umask=0000 ;;
		exfat|ntfs|ntfs3) sudo mount "$device" "$mountpoint" -o uid="$(id -u)",gid="$(id -g)" ;;
		*) sudo mount "$device" "$mountpoint" ;;
	esac &&
	notify-send "đź’ľ Drive Mounted" "$device mounted to $mountpoint"
	;;
đź“±*)	mtpnum=${chosen#đź“±}
	mtpnum=${mtpnum%%:*}
	mphone() { sudo simple-mtpfs -o allow_other -o fsname="simple-mtpfs-$mtpnum" --device "$mtpnum" "$mountpoint"; }
	notify-send 'âť— Note' 'Remember to allow file access on your phone now.'
	getmount
	if	mphone || { sleep 5; mphone; }
	then	notify-send "đź¤– Android Mounted" "Android device mounted to $mountpoint"
	fi
esac
