#!/bin/dash

set -e

case $1 in
unmount)
	mounteddroids=$(grep simple-mtpfs /etc/mtab | awk '{print "📱" $2}' | sed 's/\\040/ /g')
	mounteddrives=$(lsblk -nrpo NAME,TYPE,SIZE,MOUNTPOINT \
		| awk '($2=="part"||$2=="rom")&&$4!~/\/boot|\/home$|SWAP/&&length($4)>1{printf "💾%s (%s)\n",$4,$3}' \
		| sed 's/\\x20/ /g')
	allunmountable=$(printf "%s\n%s" "$mounteddroids" "$mounteddrives" | sed "/^$/d")
	test "$allunmountable"
	selected=$(printf '%s\n' "$allunmountable" | dmenu -i -p 'Unmount which drive?')
	test "$selected"
	case $selected in
		💾*) target=${selected%% (*} ;;
		📱*) target=$selected
	esac
	sudo umount -l "/${target#*/}"
	notify-send "Device unmounted." "$selected has been unmounted."
	exit
esac

phones=
phones_raw=$(simple-mtpfs -l 2>/dev/null||:)
if [ -n "$phones_raw" ]; then
	mountedphones=$(grep simple-mtpfs /etc/mtab||:)
	phones=$(printf '%s\n' "$phones_raw" \
		| while IFS= read -r line; do
			num=${line%%:*}
			case $mountedphones in
			*"simple-mtpfs-$num "*) ;;
			*) printf '📱%s\n' "$line"
			esac
		done
	)
fi

normalparts=$(lsblk -nrpo NAME,TYPE,SIZE,LABEL,FSTYPE,MOUNTPOINT | sed 's/ /:/g' | awk -F: \
	'($2=="part"||$2=="rom")&&$5!="crypto_LUKS"&&$6==""{printf "💾%s (%s)%s%s\n",$1,$3,$4?" "$4:"",$5?" "$5:""}'
)

alldrives=$(printf "%s\n%s" "$phones" "$normalparts" | sed "/^$/d")
test "$alldrives"

chosen=$(printf '%s\n' "$alldrives" | dmenu -i -p 'Mount which drive?')

getmount(){
	mp=$(find /mnt /media /home -maxdepth 1 -type d 2>/dev/null | dmenu -i -p 'Mount this drive where?')
	test -n "$mp"
	if [ ! -d "$mp" ]; then
		mkdiryn=$(printf "No\\nYes" | dmenu -i -p "$mp does not exist. Create it?")
		[ "$mkdiryn" = Yes ] && { mkdir -p "$mp" || sudo mkdir -p "$mp"; }
	fi
}

case $chosen in
💾*)
	chosen=${chosen#💾}
	chosen=${chosen%% *}
	if sudo mount "$chosen"; then
		notify-send "💾Drive Mounted." "$chosen mounted."
		exit
	fi
	getmount
	parttype=$(lsblk -nro FSTYPE "$chosen")
	case $parttype in
		vfat) sudo mount -t vfat "$chosen" "$mp" -o rw,umask=0000 ;;
		exfat|ntfs|ntfs3) sudo mount "$chosen" "$mp" -o uid="$(id -u)",gid="$(id -g)" ;;
		*) sudo mount "$chosen" "$mp"
	esac
	notify-send "💾Drive Mounted." "$chosen mounted to $mp."
	;;
📱*)
	number=${chosen#📱}
	number=${number%%:*}
	mphone() { sudo simple-mtpfs -o allow_other -o fsname="simple-mtpfs-$number" --device "$number" "$mp"; }
	notify-send '❗Note' 'Remember to allow file access on your phone now.'
	getmount
	mphone || { sleep 5; mphone; }
	notify-send "🤖 Android Mounted." "Android device mounted to $mp."
esac
