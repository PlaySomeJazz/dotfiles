#!/bin/dash

set -e

case $1 in
unmount)
	list=`
		: MOUNTED DROIDS
		findmnt -t fuse -Pno SOURCE,TARGET | while read -r line; do
			eval "$line"
			case $SOURCE in simple-mtpfs-*)
				printf '📱%s (%s)\n' "$TARGET" "$SOURCE"
			esac
		done
		: MOUNTED VOLUMES
		findmnt --real -Pno SOURCE,TARGET,SIZE | while read -r line; do
			eval "$line"
			case $TARGET in /boot*|/) continue; esac
			printf '💾%s (%s, %s)\n' "$TARGET" "$SOURCE" "$SIZE"
		done
	`
	test "$list"
	chosen=`printf '%s\n' "$list" | dmenu -i -p 'Unmount which device?'`
	test "$chosen"
	target=${chosen#?}
	target=${target%% (*}
	sudo umount -l "$target"
	notify-send "Device unmounted" "$chosen has been unmounted"
	exit
esac

list=`
	: MOUNTABLE DROIDS
	simple-mtpfs -l 2>/dev/null | while read -r line; do
		mtpnum=${line%%:*}
		findmnt -nS simple-mtpfs-$mtpnum >/dev/null 2>&1 ||
		printf '📱%s\n' "$line"
	done
	: MOUNTABLE VOLUMES
	lsblk -Ppo NAME,TYPE,SIZE,LABEL,FSTYPE,MOUNTPOINT | while read -r line; do
		eval "$line"
		test -n "$MOUNTPOINT" -o \( "$TYPE" != part -a "$TYPE" != rom \) && continue
		printf '💾%s (%s%s%s)\n' "$NAME" "$SIZE" "${LABEL:+, $LABEL}" "${FSTYPE:+, $FSTYPE}"
	done
`

test "$list"
chosen=`printf '%s\n' "$list" | dmenu -i -p 'Mount which device?'`

askmp() {
	mountpoint=`find /mnt /usr/$USER -maxdepth 1 -type d -empty 2>/dev/null | dmenu -i -p 'Mount this device where?'`
	test "$mountpoint"
	if [ ! -d "$mountpoint" ]; then
		a=`printf 'No\nYes' | dmenu -i -p "$mountpoint does not exist. Create it?"`
		case $a in Yes) mkdir -p "$mountpoint" || sudo mkdir -p "$mountpoint"; esac
	fi
}

case $chosen in
💾*)	device=${chosen#💾}
	device=${device%% (*}
	sudo mount "$device" && notify-send "💾 Device Mounted" "$device mounted" || exit
	askmp
	case `lsblk -no FSTYPE "$device"` in
		vfat) sudo mount -t vfat "$device" "$mountpoint" -o rw,umask=0000 ;;
		exfat|ntfs*) sudo mount "$device" "$mountpoint" -o uid="$(id -u)",gid="$(id -g)" ;;
		*) sudo mount "$device" "$mountpoint"
	esac
	notify-send "💾 Device Mounted" "$device mounted to $mountpoint"
	;;
📱*)	mtpnum=${chosen#📱}
	mtpnum=${mtpnum%%:*}
	mountdroid() { sudo simple-mtpfs -o allow_other -o fsname="simple-mtpfs-$mtpnum" --device "$mtpnum" "$mountpoint"; }
	notify-send '❗ Note' 'Remember to allow file access on your Android now.'
	askmp
	mountdroid || { sleep 5; mountdroid; }
	notify-send "🤖 Android Mounted" "Android device mounted to $mountpoint"
esac
