#!/bin/sh

bmdirs=${XDG_CONFIG_HOME?}/shell/bm-dirs
bmfiles=${XDG_CONFIG_HOME?}/shell/bm-files

# Output locations. Unactivated progs should go to /dev/null.
shell_shortcuts=$XDG_CONFIG_HOME/shell/shortcutrc
zsh_named_dirs=$XDG_CONFIG_HOME/shell/zshnameddirrc
lf_shortcuts=$XDG_CONFIG_HOME/lf/shortcutrc

# Remove, prepare files
rm -f "$lf_shortcuts" "$zsh_named_dirs" 2>/dev/null
printf "# vim: filetype=sh\\nalias " > "$shell_shortcuts"
printf "# vim: filetype=sh\\nexport " > "$zsh_named_dirs"

# Format the `directories` file in the correct syntax and sent it to all three configs.
eval "printf '%s\n' \"$(cat "$bmdirs")\"" |
awk "!/^\s*#/ && !/^\s*\$/ {gsub(\"\\\s*#.*$\",\"\");
	printf(\"%s='cd %s && ls -A' \\\\\n\",\$1,\$2)	>> \"$shell_shortcuts\" ;
	printf(\"%s=%s \\\\\n\",\$1,\$2)		>> \"$zsh_named_dirs\"  ;
	printf(\"map f%s cd \42%s\42\n\",\$1,\$2)	>> \"$lf_shortcuts\" }"

# Format the `files` file in the correct syntax and sent it to both configs.
eval "printf '%s\n' \"$(cat "$bmfiles")\"" |
awk "!/^\s*#/ && !/^\s*\$/ {gsub(\"\\\s*#.*$\",\"\");
	printf(\"%s='\$EDITOR %s' \\\\\n\",\$1,\$2)		>> \"$shell_shortcuts\" ;
	printf(\"map F%s \$\$EDITOR \42%s\42\n\",\$1,\$2)	>> \"$lf_shortcuts\" }"
