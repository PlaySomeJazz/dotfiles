#!/bin/sh
[ $# -ne 1 ] && exit
: ${S=`for b in \
	https://wp1.com/category \
	https://wp2.com/category \
	https://wp3.com/category
do echo "$b (\`curl -4sL $b/$1/|awk -vRS=page/ '$1+0>m{m=$1+0}END{print m?m:1}'\`)" & done | fzf -m
`}

[ "$S" ] || exit
case $S in *'
'*)	echo "$S" | while read l; do S="$l" A=s $0 $1; done; exit
esac

p=${S#* \(} p=${p%?} S=${S% *} R=${S%/*} d=${XDG_PICTURES_DIR:-$HOME/pictures}/scrape/$1/${R#*://}

[ "$A" ] || { echo $p pages; read p; case $p in ''|*[!0-9]*) exit; esac; }
case $S in
	*1*) f(){ grep -oP 'wp\S+(?= \d+w")';};;
	*2*) f(){ sed -nE 's|.*src=".*(wp.*)-[0-9x]+(\.[^ ]*)".*|\1\2|p';};;
	*3*) f(){ sed -En 's|.*thumb/([^"]*).*|files/src/\1|p';};;
	*4*) f(){ grep -o 'wp[^"]*jpg';}
esac

i=1 url=$S/$1/
while [ $i -le $p ]; do
	echo url = \"$url\"; i=$((i+1)) url=$S/$1/page/$i/
done \
| curl -4sLZ -K - | f \
| while read l; do printf 'url = "%s/%s"\n-O\n' $R $l; done \
| curl -4fLZ$A --parallel-max 100 --output-dir $d --create-dirs --no-clobber -K -

for f in $d/*[0-9]; do [ -f $f ] && safe mv $f ${f%.[0-9]*}; done
