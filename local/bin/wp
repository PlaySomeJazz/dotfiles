#!/bin/sh

[ $# -ne 1 ] && exit
S=$(for blog in \
	https://wp1.com/category \
	https://wp2.com/category \
	https://wp3.com/category
do	{
	n=$(curl -4sL $blog/$1/ | awk -vRS=page/ '$1+0>m{m=$1+0}END{print m?m:1}')
	echo "$blog ($n)"
	} &
done | fzf
)

[ ! "$S" ] && exit
n=${S#* \(} n=${n%?}
S=${S% *}

echo $n pages; read p; case $p in ''|*[!0-9]*) exit; esac
case $S in
	*1*) f(){ grep -oP 'wp\S+(?= \d+w")';};;
	*2*) f(){ sed -nE 's|.*src=".*(wp.*)-[0-9x]+(\.[^ ]*)".*|\1\2|p';};;
	*3*) f(){ sed -En 's|.*thumb/([^"]*).*|files/src/\1|p';};;
	*4*) f(){ grep -o 'wp[^"]*jpg';}
esac

b=${S#*://} b=${b%/*}
d=${XDG_PICTURES_DIR:-$HOME/pictures}/scrape/$1_$b
R=${S%/*}

i=1
url=$S/$1/
while [ $i -le $p ]; do
	echo url = \"$url\"
	i=$((i+1))
	url=$S/$1/page/$i/
done \
| curl -4sLZ -K - | f \
| while read l; do printf 'url = "%s/%s"\n-O\n' $R $l; done \
| curl -4fLZ --parallel-max 100 --output-dir $d --create-dirs --no-clobber -K -

for f in $d/*[0-9]; do [ -f $f ] && safe mv $f ${f%.[0-9]*}; done
