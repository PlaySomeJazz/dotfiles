#!/bin/sh

log() { printf "\033[2K\r\033[1;${2:-33}m${1}\033[0m" ; }
del() { ed - $notes <<-\#
	1d
	w
	#
}
add() { printf '%s\n' "$note" >>$c && del ; }

notes=${1:-$NOTES_FILE} ; [ ! -f $notes ] && log 'Add notes file\n' 31 && exit
case $notes in /*) ;; *) notes=`pwd`/$notes; esac
dir=$NOTES_DIR ; [ ! -d $dir ] && mkdir -p $dir
default=Chores

chdir $dir
[ ! -f $default ] && >$default
while test -s $notes; do
	tput clear
	read -r note <$notes; [ -z "$note" ] && del && continue
	log "$note\n\n"
	c=`printf '%s\n' * '<Add category>' '<Delete>' | fzf`
	[ -z "$c" ] && tput clear && log 'Interrupted\n' 31 && exit
	case $c in
		*Add*)	log 'Enter title:\n'; read c; [ -z $c ] && continue
			[ ! -f $c ] && add || { tput clear; log '!\n' 31; sleep 1;} ;;
		*Del*)	log 'Delete?' 32; a=`printf '%s\n' yes no | fzf`
			[ $a = yes ] && del;;
		*)	add
	esac
done

tput clear
for i in *; do [ -s $i ] && mail -s $i $USER <$i && >$i; done
log 'All done!\n' 34
