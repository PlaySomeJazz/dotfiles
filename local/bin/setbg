#! /bin/sh

n=yes f= b=${XDG_DATA_HOME?}/bg

case $1 in
-s)	n=no
	shift
esac
case $1 in
/*)	f=$1 ;;
?*)	f=`pwd`/$1
esac

test "$f" &&
case `file -iL "$f"` in
*image/*)	ln -sf "$f" "$b" ;;
*inode/dir*)	ln -sf "`find "$f" -iregex '.*\(jpe?g\|png\)$' -type f -print0 | shuf -z -n 1`" "$b" ;;
*)		notify-send Error 'Not a valid image or directory'
		exit 1
esac

xwallpaper --zoom "$b" &&
test "$f" -a $n = yes &&
notify-send -i "$b" 'Wallpaper changed'
