#! /bin/sh

b=${XDG_DATA_HOME?}/bg s=no

while getopts s o; do case $o in s) s=yes; esac done
shift `expr $OPTIND - 1`

test "$1" &&
case `file --mime-type -Lb "$1"` in
image/*)
	ln -sf "$1" "$b" &&
	test "$s" = no && notify-send -i "$b" 'Changing wallpaper...'
	;;
inode/directory)
	ln -sf "`find "$1" -iregex '.*\(jpe?g\|png\)$' -type f | shuf -n 1`" "$b" &&
	test "$s" = no && notify-send -i "$b" 'Random Wallpaper chosen'
	;;
*)
	notify-send Error 'Not a valid image or directory'
	exit 1
esac

xwallpaper --zoom "$b"
