#! /bin/sh

conflict="eval notify-send 'conflicting options'; exit 1"

while getopts o:c:pvatid opt
do
	case $opt in
	o)	oarg=$OPTARG;;
	c)	test "$flag" && $conflict
		flag=$opt
		carg=$OPTARG;;
	p)	playlist=--yes-playlist;;
	i|d)	test "$flag" && $conflict
		flag=$opt;;
	v|a|t)	case $flag in
		*[!vat\ ]*) $conflict;;
		*$opt*)	: skip duplicates ;;
		*)	flag="$flag $opt"
		esac;;
	\?)	exit 1
	esac
done
shift `expr $OPTIND - 1`

case $# in
0)	set - `xclip -o`
	case $# in
	0)	notify-send 'no urls provided'
		exit 1
	esac
esac

for url do case $url in
http://*|https://*)
	case $url in
	*m3u8*)	name=`expr $url : '.*/\([^?]*\)'`;;
	*)	name=$url
	esac
	for o in $flag
	do
		case $o in
		c)	id=`tsp $carg "$url"`;;
		v)	id=`tsp yt-dlp \
				${playlist:---no-playlist} \
				--progress --print after_move:title \
				-i \
				-o "${oarg:-$XDG_VIDEOS_DIR/W}/%(title)s-\`date +%s\`.%(ext)s" \
				"$url"`;;
		a)	id=`tsp yt-dlp \
				${playlist:---no-playlist} \
				--progress --print after_move:title \
				--embed-metadata \
				-x -f bestaudio \
				-o "${oarg:-$XDG_MUSIC_DIR}/%(title)s.%(ext)s" \
				"$url"`;;
		t)	id=`tsp yt-dlp \
				${playlist:---no-playlist} \
				--progress --print after_move:title \
				--skip-download --write-thumbnail \
				-o "${oarg:-$XDG_PICTURES_DIR}/%(title)s.%(ext)s" \
				"$url"`;;
		i)	id=`tsp gallery-dl \
				--cookies-from-browser firefox \
				-d "${oarg:-$XDG_PICTURES_DIR}" \
				"$url"`;;
		d)	id=`tsp aria2c \
				-d "${oarg:-$WL}" \
				"$url"`
		esac
		notify-send -i $PIX/dlpending.svg 'Queuing download' "[$o] $name"
		pkill -10 status
		{
			if tsp -w $id
			then	case $o in
				[vat])	case $name in
					*m3u8*)	;;
					*)	name=`tsp -c $id | tr '\r' '\n' | tail -1`
					esac
				esac
				notify-send -i $PIX/dlcomplete.svg 'Download complete' "[$o] $name"
			else	msg=`tsp -c $id | tail -3`
				N=`notify-send -u critical -A copy "[$o] $name" "${msg:-Download failed}"`
				test $N && echo "$url" | xclip -sel c
			fi
			pkill -10 status
		} &
	done
esac done
