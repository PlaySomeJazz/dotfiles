#! /bin/sh -

o=

if test $# -lt 3 -o \( "X$1" != Xmv -a "X$1" != Xcp \); then
	echo try again 1>&2
	exit 1
fi

extensions='
mp4 mkv wmv webm jpg jpeg png webp gif avif mp3 m4a m4b opus wav flac pdf PDF md
doc docx odt djvu azw3 epub mobi txt apk html tar.gz tar.bz2 tar.xz gz zip rar 7z
'

cmd=$1
shift

case $cmd in
cp)	o=-R
esac

set -f
for dest do :; done

if test $# -gt 2 -a ! -d "$dest"; then
	echo \'"$dest"\' is a file 1>&2
	exit 1
fi

while test $# -gt 1; do
	if test -d "$dest"
	then	target="$dest/`basename "$1"`"
	else	target="$dest"
	fi

	if test -f "$target" -o -d "$target" || test -h "$target"
	then	ext=
		if test -f "$target"
		then	case "$target" in
			?*.?*)	for i in $extensions
				do	case "$target" in
					*.$i)	ext=.$i
						break
					esac
				done
				name=`expr "x$target" : "x\(.*\)$ext$"` ;;
			*)	name="$target"
			esac
		else
			name="$target"
		fi
		c=1
		while test -f "$target" -o -d "$target" || test -h "$target"; do
			target="${name}_RENAMED${c}${ext}"
			c=`expr $c + 1`
		done
	fi
	$cmd $o -- "$1" "$target"
	shift
done
