#! /bin/sh

foundfiles() { for f in * .[!.]* ..?*; do [ -e "$f" ] && return; done; }

if foundfiles; then
	:
else
	notify-send 'Nothing to sort'
	exit
fi

export watch music
watch=${WL?}
music=${XDG_MUSIC_DIR?}

chdir "${1:-/srv/media/torrents}" || exit

for dir in $watch $music; do [ ! -d $dir ] && mkdir -p $dir; done

find . -type f \( -iname '*.mp4' -o -iname '*.mkv' \) -exec sh -c 'safe mv "$@" $watch' sh {} +

find . ! -name . -prune -type d -exec sh -c 'for dir do [ -n "`find "$dir" -type f \( -iname "*.mp3" -o -iname "*.m4b" -o -iname "*.flac" -o -iname "*.m4a" -o -iname "*.opus" \) -print -quit`" ] && safe mv "$dir" $music; done' sh {} +

find . -depth ! -name . -prune -type d -exec sh -c 'for dir do [ -z "`find "$dir" -type f \( -iname "*.pdf" -o -iname "*.djvu" -o -iname "*.epub" -o -iname "*.mobi" -o -iname "*.zip" -o -iname "*.rar" \) -print -quit`" ] && rm -rf "$dir"; done' sh {} +

notify-send 'Your files are sorted'
